{
  "name": "team-task-manager",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "parcel client/src/index.html --port 1234",
    "build": "parcel build client/src/index.html --dist-dir dist --public-url /",
    "start": "node server/index.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "buffer": "^6.0.3",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "parcel": "^2.11.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
